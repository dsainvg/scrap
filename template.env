# NVIDIA API Configuration
# Get your API key from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Multiple API Keys for Higher Rate Limits (Optional but Recommended)
# Uncomment and add additional keys. The system will rotate between them automatically.
# NVIDIA_API_KEY_1=your_first_nvidia_api_key_here
# NVIDIA_API_KEY_2=your_second_nvidia_api_key_here
# NVIDIA_API_KEY_3=your_third_nvidia_api_key_here
# Or use comma-separated: NVIDIA_API_KEYS=key1,key2,key3

# NVIDIA Model Selection (optional)
# Options: qwen/qwen3.5-397b-a17b (default), meta/llama-3.1-70b-instruct, etc.
# See: https://build.nvidia.com/explore/discover
NVIDIA_MODEL=qwen/qwen3.5-397b-a17b

# Note: Scraper configuration (timeout, delay, depth) is now in utils/config.py
# Edit utils/config.py to change these settings.